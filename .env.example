# Frontend: set this before building if you want the browser client to POST
# completed CPU-vs-CPU match logs to a server endpoint.
VITE_AUTOMATCH_LOG_ENDPOINT=http://127.0.0.1:8787/api/auto-match-logs

# Local Node log server defaults.
AUTOMATCH_LOG_HOST=127.0.0.1
AUTOMATCH_LOG_PORT=8787
AUTOMATCH_LOG_STORAGE_DIR=./server-data/auto-match-logs
AUTOMATCH_LOG_ALLOWED_ORIGINS=*
AUTOMATCH_LOG_RATE_LIMIT_PER_MINUTE=30
AUTOMATCH_LOG_MAX_BODY_BYTES=1048576
